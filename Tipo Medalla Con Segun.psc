Algoritmo tipoMedallaConSegun
	Definir posicion Como Entero
	Escribir "indique posicion"
	Leer posicion
	Segun posicion Hacer
		1:
			Escribir "entregar medalla de oro"
		2:
			escribir "entregar medalla de plata"
		3:
			escribir "entregar medalla de bronce"
		De Otro Modo:
			Escribir "entregar certificado de participacion"
	Fin Segun
FinAlgoritmo

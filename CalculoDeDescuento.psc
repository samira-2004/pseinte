Algoritmo CalculoDeDescuento
	Definir PrecioProducto Como Real
	Definir porcentajeDescuento Como Real
	PrecioProducto=450.5
	porcentajeDescuento=0.1
	Definir descuento Como Real
	Definir precioFinal como Real
	descuento=PrecioProducto*porcentajeDescuento
	precioFinal=PrecioProducto-descuento
	Escribir "El precio Final es:" ,precioFinal
FinAlgoritmo

Algoritmo DeterminarMedalla
	Definir posicion como entero
	escribir "ingrese posicion "
	Leer posicion
	si posicion= 1 Entonces
		Escribir "entregar medalla de oro"
	SiNo
		si posicion= 2 Entonces
			Escribir "entregar medalla de plata"
		SiNo
			
		si posicion= 3 Entonces
			Escribir " entregar medalla de bronce"
		SiNo
			Escribir "entregar certificado de posicion"
		FinSi
			
	FinSi
	
		
	FinSi
FinAlgoritmo
